{
    "compilerOptions": {
        "module": "nodenext",
        "target": "es2020",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "noImplicitAny": true,
        "typeRoots": ["./node_modules/@types", "./src/@types"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules","dist"]
}